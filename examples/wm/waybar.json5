// Waybar custom module. Paste into ~/.config/waybar/config and add
// "custom/mvad" to modules-{left,center,right}.
// CSS classes: #custom-mvad.connected, #custom-mvad.disconnected.
"custom/mvad": {
    "exec": "mvad status --format=waybar",
    "return-type": "json",
    "interval": 2,
    "on-click": "mvad status >/dev/null && exec pkexec mvad disconnect || exec pkexec mvad reconnect"
}
